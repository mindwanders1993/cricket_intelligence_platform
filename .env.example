# Core environment
ENV=dev
LOG_LEVEL=INFO
PROJECT_NAME=cricket_intelligence_platform

# Docker network name (compose)
DOCKER_NETWORK=cip_net

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminsecret
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_REGION=us-east-1
MINIO_BUCKET_LANDING=cricket-landing
MINIO_BUCKET_BRONZE=cricket-bronze
MINIO_BUCKET_SILVER=cricket-silver
MINIO_BUCKET_GOLD=cricket-gold
MINIO_BUCKET_CONTROL=cricket-control

# S3-style endpoint for clients
MINIO_S3_ENDPOINT=http://minio:9000

# PostgreSQL (Airflow + control schema in same DB for v1)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cricket_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Airflow
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__FERNET_KEY=changeme_fernet_key
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW_WEBSERVER_PORT=8080

# Iceberg REST catalog
ICEBERG_CATALOG_HOST=iceberg-catalog
ICEBERG_CATALOG_PORT=8181
ICEBERG_CATALOG_NAME=cricket_iceberg
ICEBERG_CATALOG_URI=http://iceberg-catalog:8181

# Local host-mapped ports
HOST_MINIO_PORT=9000
HOST_MINIO_CONSOLE_PORT=9001
HOST_AIRFLOW_PORT=8080
HOST_POSTGRES_PORT=5432
HOST_ICEBERG_CATALOG_PORT=8181

# Paths on host (for bind mounts if needed)
HOST_DATA_DIR=./.data
HOST_MINIO_DATA_DIR=./.data/minio
HOST_POSTGRES_DATA_DIR=./.data/postgres
HOST_AIRFLOW_HOME=./.data/airflow
