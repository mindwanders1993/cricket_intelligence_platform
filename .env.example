# ============================================================================
# Cricket Intelligence Platform — Development Environment
# Copy to .env and replace CHANGE_ME values before running.
# ============================================================================

# ─── Core ────────────────────────────────────────────────────────────────────
ENV=dev
LOG_LEVEL=INFO
PROJECT_NAME=cricket_intelligence_platform

# ─── MinIO (S3-compatible object storage) ────────────────────────────────────
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=adminsecret
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_REGION=us-east-1
# Internal Docker endpoint — used by all Python code running inside containers
MINIO_S3_ENDPOINT=http://minio:9000
# Exposed host ports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=cricket_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ─── Iceberg REST Catalog ─────────────────────────────────────────────────────
# Internal URI used by Python code inside containers and Spark jobs
ICEBERG_REST_URI=http://iceberg-rest:8181
ICEBERG_REST_PORT=8181
ICEBERG_WAREHOUSE_BUCKET=iceberg-warehouse

# ─── Airflow ─────────────────────────────────────────────────────────────────
# Generate a Fernet key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME_generate_with_command_above
# Any random string (≥16 chars) for the webserver session signing key
AIRFLOW_SECRET_KEY=dev-secret-change-in-production
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@cricket-platform.local
AIRFLOW_WEBSERVER_PORT=8080

# ─── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_PORT=5050

# ─── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_PORT=5001

# ─── Spark (local dev — override for cluster deploy) ─────────────────────────
SPARK_MASTER=local[*]
SPARK_DRIVER_MEMORY=2g
